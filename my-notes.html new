<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Notes</title>
  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    .notes-page{
      min-height:100vh;
      background:
      radial-gradient(circle at 15% 20%, rgba(193,179,147,0.25), transparent 30%),
      radial-gradient(circle at 85% 25%, rgba(193,179,147,0.20), transparent 28%),
      radial-gradient(circle at 50% 80%, rgba(193,179,147,0.18), transparent 32%),
      radial-gradient(circle at 70% 60%, rgba(75,79,62,0.30), transparent 35%),
      linear-gradient(140deg, #3A2F2B 0%, #3A2F2B 40%, #4B4F3E 100%);
    }

    .notes-section{
      position:relative;
      max-width:1200px;
      margin:0 auto;
      padding:150px 40px 70px;
    }

    .notes-header{
      text-align:center;
      margin-bottom:48px;
    }

    .notes-header h1{
      font-size:46px;
      color:#EDE8DC;
      margin-bottom:14px;
    }

    .notes-subtitle{
      font-size:17px;
      color:#EDE8DC;
      line-height:1.7;
      max-width:640px;
      margin:0 auto;
    }

    .note-input-box{
      background-color:#4B4F3E;
      padding:26px 34px;
      display:flex;
      align-items:center;
      gap:22px;
      margin-bottom:38px;
      flex-wrap:wrap;
    }

    .note-input{
      flex:1;
      min-width:240px;
      height:48px;
      border:1px dashed #EDE8DC;
      background-color:#f8f8f8;
      padding:0 16px;
      font-size:15px;
      color:#333;
      outline:none;
    }

    .priority-select{
      width:170px;
      height:48px;
      border:1px dashed #EDE8DC;
      background-color:#f8f8f8;
      padding:0 12px;
      font-size:15px;
      color:#333;
      outline:none;
    }

    .save-btn{
      width:125px;
      height:40px;
      border:none;
      background-color:#EDE8DC;
      color:#2f241d;
      font-size:15px;
      cursor:pointer;
    }

    .saved-title{
      font-size:38px;
      color:#EDE8DC;
      margin-bottom:22px;
    }

    .notes-list{
      display:flex;
      flex-direction:column;
      gap:24px;
    }

    .note-card{
      background-color:#4B4F3E;
      min-height:92px;
      padding:0 18px 0 16px;
      display:flex;
      align-items:center;
    }

    .note-card.priority-1{
      background-color:#8B3A3A;
    }

    .note-card.priority-2{
      background-color:#9A8B3A;
    }

    .note-card.priority-3{
      background-color:#4B6B4B;
    }

    .note-left{
      display:flex;
      align-items:center;
      gap:28px;
      flex:1;
      min-width:0;
    }

    .note-check{
      width:27px;
      height:27px;
      accent-color:#7a4d2c;
      flex-shrink:0;
      cursor:pointer;
    }

    .note-text{
      font-size:17px;
      color:#EDE8DC;
      line-height:1.6;
      word-break:break-word;
    }

    .notes-bottom{
      margin-top:32px;
      display:flex;
      justify-content:space-between;
      align-items:flex-end;
    }

    .delete-all-btn{
      height:38px;
      padding:0 18px;
      border:none;
      background-color:#EDE8DC;
      color:#2f241d;
      font-size:15px;
      cursor:pointer;
    }

    .save-btn:hover{
      background-color:#e6dfd7;
    }

    .delete-all-btn:hover{
      background-color:#9f9f9f;
      color:white;
    }

    @media (max-width: 768px){
      .notes-section{
        padding:140px 20px 60px;
      }

      .notes-header h1{
        font-size:36px;
      }

      .note-input-box{
        flex-direction:column;
        align-items:stretch;
        padding:20px;
      }

      .save-btn{
        width:100%;
      }

      .priority-select{
        width:100%;
      }

      .note-card{
        flex-direction:column;
        align-items:stretch;
        padding:18px;
      }

      .note-left{
        gap:18px;
        align-items:flex-start;
      }

      .notes-bottom{
        margin-top:32px;
        display:flex;
        justify-content:flex-end;
      }
    }

    /* =============================== */
    /* Lesson Navigation Buttons */
    /* =============================== */
    .lesson-buttons {
      width: min(1150px, 92%);
      margin: 30px auto 80px;
      display: flex;
      justify-content: space-between;
    }

    .lesson-buttons a {
      text-decoration: none;
      font-size: 1.5rem;
      font-weight: 600;
      color:#C1B393;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: all 0.3s ease;
    }

    .btn-back,
    .btn-next {
      background:#C1B393;
      color:#2f241d;
      border:1px solid #b9997d;
    }

    .btn-back:hover,
    .btn-next:hover {
      background:#7a4d2c;
      color:#EDE8DC;
      transform: translateY(-3px);
    }
  </style>
</head>
<body>

  <div class="notes-page">

    <header>
      <nav class="navbar">

        <div class="logo">
          <img src="logo.png" alt="Bean to Brew Logo">
        </div>

        <ul class="nav-links">
          <li><a href="index.html">Home</a></li>
          <li><a href="BrewSchool.html">Brew School</a></li>
          <li><a href="CoffeLab.html">Coffee Lab</a></li>
          <li><a href="student-dashboard.html" class="active">Student Dashboard</a></li>
          <li><a href="About-us.html">About Us</a></li>
          <li><a href="Contact.html">Contact Us</a></li>
        </ul>

        <div class="nav-right">
          <button class="mode-btn">☀️</button>
          <input type="text" placeholder="Search" class="search-box">
        </div>

      </nav>
    </header>

    <main>
      <section class="notes-section">

        <div class="path-wrap">
          <div class="path-breadcrumb">
            <a href="index.html">Home</a>
            <span>›</span>
            <a href="student-dashboard.html">Student Dashboard</a>
            <span>›</span>
            <span>My Notes</span>
          </div>
        </div>

        <div class="notes-header">
          <h1>My Notes</h1>
          <p class="notes-subtitle">
            Manage your note by adding new note, viewing and deleting the<br>
            saved ones
          </p>
        </div>

        <div class="note-input-box">
          <input type="text" class="note-input" id="noteInput" placeholder="Enter your note here..">

          <select id="prioritySelect" class="priority-select">
            <option value="">Choose Priority</option>
            <option value="1">Priority 1</option>
            <option value="2">Priority 2</option>
            <option value="3">Priority 3</option>
          </select>

          <button class="save-btn" id="saveBtn">Save</button>
        </div>

        <h2 class="saved-title">Saved Notes</h2>

        <div class="notes-list" id="notesList">
        </div>

        <div class="notes-bottom">
          <button class="delete-all-btn">Delete All selected</button>
        </div>

      </section>

      <div class="lesson-buttons">
        <a href="student-dashboard.html">← Back</a>
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-top">
        <div class="footer-logo">
          <img src="logo.png" alt="Bean to Brew Logo">
        </div>

        <div class="footer-contact">
          <h3>Contact us</h3>
          <p>+966504256847</p>
          <p>BeantoBrew@gmail.com</p>
        </div>

        <div class="footer-social">
          <h3>Follow us</h3>
          <div class="social-icons">
            <a href="https://instagram.com">
              <img src="instagramicon.png" alt="Instagram">
            </a>
            <span class="social-divider"></span>
            <a href="https://instagram.com">
              <img src="Xicon.png" alt="X">
            </a>
          </div>
        </div>
      </div>

      <p class="footer-note">Learn, explore, and enjoy the world of coffee.</p>
      <p class="copyright">© 2026 Bean to Brew. All rights reserved.</p>
    </footer>

  </div>

  <script>
    const noteInput = document.getElementById("noteInput");
    const prioritySelect = document.getElementById("prioritySelect");
    const saveBtn = document.getElementById("saveBtn");
    const notesList = document.getElementById("notesList");
    const deleteBtn = document.querySelector(".delete-all-btn");

    let notes = JSON.parse(localStorage.getItem("myNotes")) || [];

    function renderNotes() {
      notesList.innerHTML = "";

      notes.forEach((note, index) => {
        const noteCard = document.createElement("div");
        noteCard.className = "note-card priority-" + note.priority;

        noteCard.innerHTML = `
          <div class="note-left">
            <input type="checkbox" class="note-check" data-index="${index}">
            <p class="note-text">${note.text}</p>
          </div>
        `;

        notesList.appendChild(noteCard);
      });
    }

    function saveNotesToLocalStorage() {
      localStorage.setItem("myNotes", JSON.stringify(notes));
    }

    saveBtn.addEventListener("click", function () {
      const noteText = noteInput.value.trim();
      const priority = prioritySelect.value;

      if (noteText === "") {
        alert("Note cannot be empty.");
        return;
      }

      if (noteText.length < 30) {
        alert("Note must be at least 30 characters.");
        return;
      }

      if (priority === "") {
        alert("Please choose a priority.");
        return;
      }

      const newNote = {
        text: noteText,
        priority: priority
      };

      notes.push(newNote);
      saveNotesToLocalStorage();
      renderNotes();

      noteInput.value = "";
      prioritySelect.value = "";
    });

    deleteBtn.addEventListener("click", function () {
      const checkedNotes = document.querySelectorAll(".note-check:checked");

      if (checkedNotes.length === 0) {
        alert("Please select at least one note");
        return;
      }

      const confirmDelete = confirm("Are you sure you want to delete the selected notes?");

      if (!confirmDelete) {
        return;
      }

      const selectedIndexes = Array.from(checkedNotes).map(note => Number(note.dataset.index));

      notes = notes.filter((note, index) => !selectedIndexes.includes(index));

      saveNotesToLocalStorage();
      renderNotes();
    });

    renderNotes();
  </script>

</body>
</html>

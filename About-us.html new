<script>
const cardsContainer = document.querySelector(".cards");
const sortSelect = document.getElementById("sortTeachers");
const slider = document.querySelector(".teachers-slider");

let cards = Array.from(document.querySelectorAll(".card"));
let currentIndex = 1;
const totalCards = 12;
let isSliding = false;

function shuffle(array) {
  return array.sort(() => Math.random() - 0.5);
}

function goToCard(index) {
  if (index < 1) index = totalCards;
  if (index > totalCards) index = 1;

  currentIndex = index;
  const radio = document.getElementById("t" + currentIndex);

  if (radio) {
    radio.checked = true;
  }
}

function nextCard() {
  goToCard(currentIndex + 1);
}

function prevCard() {
  goToCard(currentIndex - 1);
}

function slideOnce(direction) {
  if (isSliding) return;

  isSliding = true;

  if (direction === "next") {
    nextCard();
  } else {
    prevCard();
  }

  setTimeout(function () {
    isSliding = false;
  }, 550);
}

function showCards(newCards) {
  cardsContainer.innerHTML = "";
  newCards.forEach(card => cardsContainer.appendChild(card));

  newCards.forEach((card, index) => {
    card.className = "card c" + (index + 1);
  });

  goToCard(1);
}

cards = shuffle(cards);
showCards(cards);

sortSelect.addEventListener("change", function () {
  if (this.value === "alphabetical") {
    cards.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
  } else if (this.value === "experience") {
    cards.sort((a, b) => a.dataset.exp - b.dataset.exp);
  } else {
    cards = shuffle(cards);
  }

  showCards(cards);
});

/* Keyboard arrows */
document.addEventListener("keydown", function(event) {
  if (event.key === "ArrowRight") {
    slideOnce("next");
  }

  if (event.key === "ArrowLeft") {
    slideOnce("prev");
  }
});

/* Touchpad horizontal swipe */
slider.addEventListener("wheel", function(event) {
  if (Math.abs(event.deltaX) > Math.abs(event.deltaY) && Math.abs(event.deltaX) > 25) {
    event.preventDefault();

    if (event.deltaX > 0) {
      slideOnce("next");
    } else {
      slideOnce("prev");
    }
  }
}, { passive:false });

/* Mobile touch swipe */
let startX = 0;
let startY = 0;

slider.addEventListener("touchstart", function(event) {
  startX = event.touches[0].clientX;
  startY = event.touches[0].clientY;
}, { passive:true });

slider.addEventListener("touchend", function(event) {
  const endX = event.changedTouches[0].clientX;
  const endY = event.changedTouches[0].clientY;

  const diffX = startX - endX;
  const diffY = startY - endY;

  if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
    if (diffX > 0) {
      slideOnce("next");
    } else {
      slideOnce("prev");
    }
  }
}, { passive:true });

const liveClock = document.getElementById("live-clock");

function updateClock() {
  const now = new Date();

  const time = now.toLocaleTimeString("en-US", {
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: true
  });

  if (liveClock) {
    liveClock.textContent = time;
  }
}

const backToTopBtn = document.getElementById("backToTop");

function toggleBackToTop() {
  if (window.scrollY > 300) {
    backToTopBtn.classList.add("show");
  } else {
    backToTopBtn.classList.remove("show");
  }
}

if (backToTopBtn) {
  backToTopBtn.addEventListener("click", function () {
    window.scrollTo({
      top: 0,
      behavior: "smooth"
    });
  });
}

window.addEventListener("scroll", toggleBackToTop);

updateClock();
setInterval(updateClock, 1000);
</script>

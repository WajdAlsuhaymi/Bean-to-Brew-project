<style>

/* ===== BODY ===== */
body{
    background:
      radial-gradient(circle at 15% 20%, rgba(193,179,147,0.25), transparent 30%),
      radial-gradient(circle at 85% 25%, rgba(193,179,147,0.20), transparent 28%),
      radial-gradient(circle at 50% 80%, rgba(193,179,147,0.18), transparent 32%),
      radial-gradient(circle at 70% 60%, rgba(75,79,62,0.30), transparent 35%),
      linear-gradient(140deg, #3A2F2B 0%, #3A2F2B 40%, #4B4F3E 100%);
      min-height:100vh;
    }


    /* ===== About Page ===== */
    .about-page {
      position: relative;
      padding: 150px 60px 80px;
    }

    .about-container {
      max-width: 1100px;
      margin: 0 auto;
    }

    .about-page h1 {
      font-size: 52px;
      font-family: 'Playfair Display', serif;
      color: #EDE8DC;
      margin-bottom: 35px;
    }

    .about-image {
      margin-bottom: 35px;
    }

    .about-image img {
      width: 100%;
      max-width: 850px;
      height: 350px;
      object-fit: cover;
      display: block;
      border-radius: 10px;
    }

    .about-text {
      max-width: 950px;
    }

    .about-text p {
      font-size: 20px;
      line-height: 1.9;
      margin-bottom: 22px;
      color: #EDE8DC;
    }

/* ===== TEACHERS ===== */
.teachers-section{
  padding:70px 60px;
}

.teachers-title{
  font-size:42px;
  color:#EDE8DC;
}

.teachers-desc{
  color:#EDE8DC;
  margin-bottom:30px;
}

.teacher-img{
  width:100%;
  height:150px;
  border-radius:20px;
  margin-bottom:18px;
  background: url("photo.png") center/cover no-repeat;
  background-color:#d8c3af;
}

/* ===== SORT ===== */
.teachers-topbar{
  display:flex;
  align-items:center;
  gap:15px;
  margin-bottom:30px;
}

.sort-title{
  color:#EDE8DC;
  font-weight:600;
}

.sort-select{
  padding:10px 14px;
  border-radius:10px;
  border:1px solid #b9997d;
  background:#C1B393;
  color:#2f241d;
}

/* ===== SLIDER ===== */
.teachers-slider{
  position:relative;
  max-width:900px;
  margin:auto;
}

.teachers-slider input{
  display:none;
}

.cards{
  position:relative;
  height:430px;
}

.card{
  position:absolute;
  top:50%;
  left:50%;
  width:240px;
  height:340px;
  background:#C1B393;
  border-radius:24px;
  padding:22px 18px;
  transform:translate(-50%,-50%) scale(0.45);
  opacity:0;
  transition:0.5s ease;
  text-align:center;
  box-sizing:border-box;
  overflow:hidden;
}

.card h3{
  font-size:28px;
  line-height:1.1;
  margin:0 0 8px;
  color:#2f241d;
  font-family:'Playfair Display', serif;
}

.teacher-exp{
  font-size:16px;
  margin:0 0 10px;
  color:#2f241d;
  font-weight:600;
}

.teacher-note{
  font-size:14px;
  line-height:1.4;
  color:#2f241d;
  margin:0 auto;
  max-width:90%;
}

/* center */
#t1:checked ~ .cards .c1,
#t2:checked ~ .cards .c2,
#t3:checked ~ .cards .c3,
#t4:checked ~ .cards .c4,
#t5:checked ~ .cards .c5,
#t6:checked ~ .cards .c6,
#t7:checked ~ .cards .c7,
#t8:checked ~ .cards .c8,
#t9:checked ~ .cards .c9,
#t10:checked ~ .cards .c10,
#t11:checked ~ .cards .c11,
#t12:checked ~ .cards .c12{
  transform:translate(-50%,-50%) scale(1.15);
  opacity:1;
  z-index:5;
}

/* right near */
#t1:checked ~ .cards .c2,
#t2:checked ~ .cards .c3,
#t3:checked ~ .cards .c4,
#t4:checked ~ .cards .c5,
#t5:checked ~ .cards .c6,
#t6:checked ~ .cards .c7,
#t7:checked ~ .cards .c8,
#t8:checked ~ .cards .c9,
#t9:checked ~ .cards .c10,
#t10:checked ~ .cards .c11,
#t11:checked ~ .cards .c12,
#t12:checked ~ .cards .c1{
  transform:translate(70%,-50%) scale(0.82);
  opacity:0.75;
  z-index:4;
}

/* left near */
#t1:checked ~ .cards .c12,
#t2:checked ~ .cards .c1,
#t3:checked ~ .cards .c2,
#t4:checked ~ .cards .c3,
#t5:checked ~ .cards .c4,
#t6:checked ~ .cards .c5,
#t7:checked ~ .cards .c6,
#t8:checked ~ .cards .c7,
#t9:checked ~ .cards .c8,
#t10:checked ~ .cards .c9,
#t11:checked ~ .cards .c10,
#t12:checked ~ .cards .c11{
  transform:translate(-170%,-50%) scale(0.82);
  opacity:0.75;
  z-index:4;
}

/* right far */
#t1:checked ~ .cards .c3,
#t2:checked ~ .cards .c4,
#t3:checked ~ .cards .c5,
#t4:checked ~ .cards .c6,
#t5:checked ~ .cards .c7,
#t6:checked ~ .cards .c8,
#t7:checked ~ .cards .c9,
#t8:checked ~ .cards .c10,
#t9:checked ~ .cards .c11,
#t10:checked ~ .cards .c12,
#t11:checked ~ .cards .c1,
#t12:checked ~ .cards .c2{
  transform:translate(180%,-50%) scale(0.6);
  opacity:0.35;
  z-index:3;
}

/* left far */
#t1:checked ~ .cards .c11,
#t2:checked ~ .cards .c12,
#t3:checked ~ .cards .c1,
#t4:checked ~ .cards .c2,
#t5:checked ~ .cards .c3,
#t6:checked ~ .cards .c4,
#t7:checked ~ .cards .c5,
#t8:checked ~ .cards .c6,
#t9:checked ~ .cards .c7,
#t10:checked ~ .cards .c8,
#t11:checked ~ .cards .c9,
#t12:checked ~ .cards .c10{
  transform:translate(-280%,-50%) scale(0.6);
  opacity:0.35;
  z-index:3;
}

/* arrows */
.arrows{
  display:none;
  position:absolute;
  top:50%;
  width:100%;
  justify-content:space-between;
  transform:translateY(-50%);
}

.arrow{
  font-size:72px;
  color:white;
  cursor:pointer;
  user-select:none;
}

/* show current arrows */
#t1:checked ~ .arrows-1,
#t2:checked ~ .arrows-2,
#t3:checked ~ .arrows-3,
#t4:checked ~ .arrows-4,
#t5:checked ~ .arrows-5,
#t6:checked ~ .arrows-6,
#t7:checked ~ .arrows-7,
#t8:checked ~ .arrows-8,
#t9:checked ~ .arrows-9,
#t10:checked ~ .arrows-10,
#t11:checked ~ .arrows-11,
#t12:checked ~ .arrows-12{
  display:flex;
}

.lesson-buttons {
      width: min(1150px, 92%);
      margin: 30px auto 80px;
      display: flex;
      justify-content: space-between;
    }

    .lesson-buttons a {
      text-decoration: none;
      font-size: 1.5rem;
      font-weight: 600;
      color:#C1B393;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: all 0.3s ease;
    }

    .btn-back,
    .btn-next {
      background: #C1B393;
      color: #2f241d;
      border: 1px solid #b9997d;
    }

    .btn-back:hover,
    .btn-next:hover {
      background: #7a4d2c;
      color: #EDE8DC;
      transform: translateY(-3px);
    }


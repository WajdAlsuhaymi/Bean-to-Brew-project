body{background:#F5F1EB;font-family:Arial;margin:0;}

.navbar{display:flex;align-items:center;justify-content:space-between;padding:15px 40px;background:#4B3621;color:white;}

.logo{font-weight:bold;color:white;}

.nav-links{display:flex;gap:30px;list-style:none;}

.nav-links li{cursor:pointer;color:white;}

.page-title{font-size:42px;margin:30px 60px;color:#4B3621;}

.hero img{width:100%;height:300px;object-fit:cover;}

.lessons{display:grid;grid-template-columns:repeat(3,1fr);gap:60px;padding:60px 120px;}

.lesson-card{background:white;border:1px solid #e0e0e0;padding:20px;text-align:center;width:220px;margin:auto;}

.lesson-card img{width:180px;height:120px;object-fit:cover;margin-bottom:10px;}

.lesson-card p{font-size:12px;color:#666;margin-bottom:15px;}

.lesson-card button{background:#6B4F3A;color:white;border:none;padding:8px 20px;margin-top:10px;cursor:pointer;}

.footer{background:#4B3621;color:white;display:flex;justify-content:space-around;align-items:center;padding:40px;margin-top:80px;}

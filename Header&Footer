body{
  padding-top: 80px;
}

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;

  display: flex;
  justify-content: space-between;
  align-items: center;

  background-color: #26231F;
  padding: 12px 40px;
  z-index: 1000;
}

.logo img{
  height: auto;
  width: 60px;
  display: block;
}

.nav-links {
  list-style: none;
  display: flex;
  align-items: center;
  gap: 18px;
  margin: 0;
  padding: 0;
}

.nav-links a {
  text-decoration: none;
  color: white;
  font-size: 16px;
  transition: 0.3s;
}

.nav-links a:hover {
  color: #f3d9b1;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.mode-btn {
  background: transparent;
  border: none;
  color: white;
  font-size: 22px;
  cursor: pointer;
}

.search-box {
  padding: 8px 12px;
  border: none;
  outline: none;
  border-radius: 20px;
  font-size: 14px;
}


  
<footer class="site-footer">

  <div class="footer-top">

    <div class="footer-logo">
      <img src="logo.png" alt="Bean to Brew Logo">
    </div>

    <div class="footer-contact">
      <h3>Contact us</h3>
      <p>+966504256847</p>
      <p>BeantoBrew@gmail.com</p>
    </div>

    <div class="footer-social">
      <h3>Follow us</h3>

      <div class="social-icons">

        <a href="javascript:void(0);">
          <img src="instagramicon.png" alt="Instagram">
        </a>

        <span class="social-divider"></span>

        <a href="javascript:void(0);">
          <img src="Xicon.png" alt="X">
        </a>

      </div>

    </div>

  </div>

  <p class="footer-note">
    Learn, explore, and enjoy the world of coffee.
  </p>

  <p class="copyright">
    © 2026 Bean to Brew. All rights reserved.
  </p>

</footer>


  
.site-footer{
  background-image:
  linear-gradient(rgba(35,24,18,0.80), rgba(35,24,18,0.80)),
  url("Headerpic.png");

  background-size: cover;
  background-position: top center;
  background-repeat: no-repeat;

  padding: 25px 20px 40px;         
  text-align: center;
  color: white;
}

.footer-top{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:12px;
  margin-bottom:5px;
}

.footer-logo img{
width:300px;
padding:10px;
filter: drop-shadow(0 5px 8px rgba(0,0,0,0.2));
}

.footer-contact h3,
.footer-social h3{
  font-family:'Playfair Display', serif;
  font-size:20px;
  margin-bottom:8px;
}

.footer-contact p{
  margin:6px 0;
  font-size:16px;
  font-weight:600;
}

.footer-social{
  text-align:center;
}

.social-icons{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:15px;
  margin-top:5px;
}

.social-icons a{
  display:flex;
  align-items:center;
  justify-content:center;
}

.social-icons img{
  width:30px;
  height:30px;
  object-fit:contain;
  transition: transform 0.25s ease;
}

.social-icons img:hover{
  transform: scale(1.15);
}

.social-divider{
  width:1px;
  height:22px;
  background:rgba(0,0,0,0.6);
}

.footer-note{
  font-size:16px;
  margin-top:15px;
}

.copyright{
  font-size:15px;
  margin-top:10px;
}
.social-icons img{
filter: brightness(1.4);
}
